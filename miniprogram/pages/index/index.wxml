<view class="page-index">
  <!-- Header -->
  <view class="hero">
    <view class="hero-icon">📊</view>
    <view class="hero-title">业绩快查</view>
    <view class="hero-desc">上市公司财务数据，一搜即得</view>
  </view>

  <!-- Search Bar -->
  <view class="search-section">
    <view class="search-box">
      <view class="search-icon">🔍</view>
      <input
        class="search-input"
        placeholder="输入上市公司名称，如：茅台、平安银行"
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="onSearch"
        focus="{{true}}"
        confirm-type="search"
      />
      <button class="search-btn" bindtap="onSearch" loading="{{searching}}">
        查询
      </button>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading" wx:if="{{searching}}">
    <view class="loading-spinner"></view>
    <text>正在搜索...</text>
  </view>

  <!-- Results -->
  <view class="results-wrap" wx:if="{{results.length > 0 && !searching}}">
    <view class="results-count">找到 <text class="count-num">{{results.length}}</text> 家公司</view>
    <view
      class="result-card"
      wx:for="{{results}}"
      wx:key="code"
      bindtap="onSelect"
      data-code="{{item.code}}"
      data-name="{{item.name}}"
    >
      <view class="rc-left">
        <view class="rc-avatar">{{item.name[0]}}</view>
      </view>
      <view class="rc-center">
        <view class="rc-name">{{item.name}}</view>
        <view class="rc-code">{{item.code}}</view>
      </view>
      <view class="rc-right">
        <view class="rc-market">{{item.market || 'A股'}}</view>
        <view class="rc-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- Empty -->
  <view class="empty-state" wx:if="{{results.length === 0 && !searching && hasSearched}}">
    <view class="empty-icon">📭</view>
    <view class="empty-title">未找到匹配的公司</view>
    <view class="empty-tip">请尝试其他关键词，如"格力"、"宁德"</view>
  </view>

  <!-- Welcome -->
  <view class="welcome" wx:if="{{!hasSearched}}">
    <view class="welcome-title">热门搜索</view>
    <view class="hot-tags">
      <view class="hot-tag" bindtap="onQuickSearch" data-kw="茅台">茅台</view>
      <view class="hot-tag" bindtap="onQuickSearch" data-kw="平安银行">平安银行</view>
      <view class="hot-tag" bindtap="onQuickSearch" data-kw="格力电器">格力电器</view>
      <view class="hot-tag" bindtap="onQuickSearch" data-kw="比亚迪">比亚迪</view>
      <view class="hot-tag" bindtap="onQuickSearch" data-kw="宁德时代">宁德时代</view>
      <view class="hot-tag" bindtap="onQuickSearch" data-kw="美的集团">美的集团</view>
    </view>

    <view class="feature-list">
      <view class="feature-item">
        <view class="fi-icon">📈</view>
        <view class="fi-text">近五年营业收入 & 每股收益</view>
      </view>
      <view class="feature-item">
        <view class="fi-icon">📉</view>
        <view class="fi-text">年度最高/最低股价走势</view>
      </view>
      <view class="feature-item">
        <view class="fi-icon">👥</view>
        <view class="fi-text">股东人数 & 资产负债率</view>
      </view>
      <view class="feature-item">
        <view class="fi-icon">📋</view>
        <view class="fi-text">公司简介 & 经营范围</view>
      </view>
    </view>

    <view class="source-note">
      数据来源：东方财富Choice · AKShare · 万得参考
    </view>
  </view>
</view>
