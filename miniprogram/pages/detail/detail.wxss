/* ====== Detail Page ====== */
.company-header {
  text-align: center;
  padding: 28px 20px 20px;
  background: #fff;
  margin-bottom: 0;
}

.company-name {
  font-size: 22px;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 6px;
}

.company-code {
  font-size: 13px;
  color: #94a3b8;
  letter-spacing: 1px;
}

.company-code text {
  display: inline-block;
  background: #f1f5f9;
  color: #64748b;
  padding: 4px 10px;
  border-radius: 10px;
  margin: 0 2px;
}

/* Profile & Scope */
.profile-text {
  font-size: 15px;
  color: #475569;
  line-height: 1.9;
  text-align: justify;
}

/* Structure */
.structure-item {
  display: flex;
  font-size: 14px;
  color: #475569;
  padding: 6px 0;
  border-bottom: 1px solid #f8fafc;
}

.structure-item:last-child {
  border-bottom: none;
}

.structure-cat {
  font-weight: 600;
  color: #334155;
  flex-shrink: 0;
  margin-right: 6px;
}

/* Today's price card */
.today-card {
  background: linear-gradient(135deg, #1a6ff5, #0d4fbf);
  color: #fff;
  border-radius: 14px;
  padding: 20px 18px;
  margin-bottom: 14px;
  box-shadow: 0 4px 16px rgba(26,111,245,0.25);
}

.today-label {
  font-size: 13px;
  opacity: 0.8;
  margin-bottom: 8px;
}

.today-price {
  font-size: 36px;
  font-weight: 800;
  letter-spacing: -1px;
}

.today-date {
  font-size: 12px;
  opacity: 0.7;
  margin-top: 4px;
}

/* Scroll table refinements */
.scroll-table {
  width: 100%;
  white-space: nowrap;
}

.t-row {
  display: flex;
  flex-direction: row;
  min-height: 48px;
  align-items: center;
}

.t-header {
  background: linear-gradient(135deg, #f0f5ff, #e8f1fe);
  border-radius: 10px 10px 0 0;
}

.t-header .t-th {
  font-weight: 700;
  color: #1a6ff5;
}

.t-th {
  flex-shrink: 0;
  width: 96px;
  padding: 14px 10px;
  font-size: 15px;
  font-weight: 600;
  text-align: center;
  border-right: 1px solid rgba(0,0,0,0.04);
}

.t-td {
  flex-shrink: 0;
  width: 96px;
  padding: 14px 10px;
  font-size: 15px;
  color: #334155;
  text-align: center;
  border-right: 1px solid #f1f5f9;
  font-variant-numeric: tabular-nums;
}

.t-label {
  width: 86px;
  font-weight: 600;
  color: #475569;
  text-align: left;
  padding-left: 6px;
  border-right: 1px solid #e2e8f0;
}

.t-row:not(.t-header) {
  border-bottom: 1px solid #f1f5f9;
}

.t-row:nth-child(odd):not(.t-header) {
  background: #f8fafc;
}

/* Highlight */
.highlight {
  color: #1a6ff5;
  font-weight: 700;
  font-size: 16px;
}

/* Shareholders summary */
.sh-summary {
  padding: 14px 6px 4px;
  font-size: 14px;
  color: #475569;
  line-height: 2.2;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.sh-summary .highlight {
  font-size: 15px;
}

/* Sources */
.sources-card {
  margin-top: 4px;
}

.source-item {
  font-size: 13px;
  color: #64748b;
  line-height: 2;
  padding: 2px 0;
}

.source-note {
  font-size: 12px;
  color: #94a3b8;
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px dashed #e2e8f0;
  line-height: 1.7;
}

/* Back button */
.back-btn {
  margin: 8px 16px 30px;
  width: calc(100% - 32px);
  max-width: 700px;
  padding: 15px;
  background: #fff;
  color: #1a6ff5;
  border: 1.5px solid #1a6ff5;
  border-radius: 14px;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  letter-spacing: 1px;
  transition: all 0.15s;
}

.back-btn:active {
  background: #1a6ff5;
  color: #fff;
}
