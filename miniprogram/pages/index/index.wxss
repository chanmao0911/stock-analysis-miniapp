.header {
  text-align: center;
  padding: 30px 0 20px;
}

.app-title {
  font-size: 22px;
  font-weight: 700;
  color: #1a73e8;
  margin-bottom: 8px;
}

.app-subtitle {
  font-size: 13px;
  color: #999;
}

.search-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20px;
}

.search-input {
  flex: 1;
  height: 44px;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 8px 0 0 8px;
  padding: 0 14px;
  font-size: 15px;
}

.search-btn {
  width: 72px;
  height: 44px;
  background: #1a73e8;
  color: #fff;
  font-size: 15px;
  border-radius: 0 8px 8px 0;
  border: none;
  padding: 0;
  line-height: 44px;
}

.result-header {
  font-size: 14px;
  color: #666;
  margin-bottom: 10px;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
}

.stock-name {
  font-size: 16px;
  font-weight: 500;
  color: #333;
}

.stock-code {
  font-size: 13px;
  color: #999;
}

.market-tag {
  display: inline-block;
  font-size: 11px;
  color: #1a73e8;
  background: #e8f0fe;
  padding: 2px 6px;
  border-radius: 4px;
  margin-left: 6px;
}

.tips {
  margin-top: 20px;
}

.tip-item {
  font-size: 13px;
  color: #666;
  line-height: 1.8;
}

.empty-state {
  padding: 20px 0;
}
